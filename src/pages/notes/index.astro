---
import SidebarLayout from "@/layouts/SidebarLayout.astro";
import { getCollection } from "astro:content";

const allNotes = (await getCollection("notes"))
  .filter((n) => !n.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

function formatDate(date: Date) {
  const y = date.getFullYear();
  const m = String(date.getMonth() + 1).padStart(2, "0");
  const d = String(date.getDate()).padStart(2, "0");
  return `${y}.${m}.${d}`;
}
---

<SidebarLayout>
  {
    allNotes.length === 0 ? (
      <p class="text-sm text-gray-400">nothing yet.</p>
    ) : (
      <ul class="space-y-0">
        {allNotes.map((note) => (
          <li>
            <a
              href={`/notes/${note.slug}`}
              class="group flex items-baseline gap-0 py-1 transition-opacity hover:opacity-60"
            >
              <span class="shrink-0 font-mono text-sm text-gray-800">{note.data.title}</span>
              <span class="relative top-[-2px] mx-2 flex-1 border-b border-dotted border-gray-300" />
              <span class="shrink-0 font-mono text-sm tracking-tight text-gray-400">{formatDate(note.data.date)}</span>
            </a>
          </li>
        ))}
      </ul>
    )
  }
</SidebarLayout>

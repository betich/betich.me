---
import { SITE_DESCRIPTION, SITE_TITLE } from "@/config";

const { className, ogImage, title: pageTitle, description } = Astro.props;
const resolvedOgImage = ogImage ?? "/og/about.png";
const resolvedTitle = pageTitle ?? "betich";
const resolvedDescription = description ?? SITE_DESCRIPTION;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-TX1HHP7FPJ"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag("js", new Date());

      gtag("config", "G-TX1HHP7FPJ");
    </script>
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="mask-icon" href="/safari-pinned-tab.svg" color="#4845DA" />
    <meta name="msapplication-TileColor" content="#4845DA" />
    <meta name="theme-color" content="#ffffff" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{resolvedTitle === "betich" ? SITE_TITLE : `${resolvedTitle} — ${SITE_TITLE}`}</title>
    <meta name="description" content={resolvedDescription} />
    <meta property="og:title" content={resolvedTitle} />
    <meta property="og:description" content={resolvedDescription} />
    <meta property="og:image" content={new URL(resolvedOgImage, Astro.site)} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={new URL(resolvedOgImage, Astro.site)} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500&family=Roboto+Mono:ital,wght@0,400;0,500;1,400&family=IBM+Plex+Thai:wght@400;500&family=Sarabun:ital,wght@0,400;0,500;0,700;1,400&display=swap" rel="stylesheet" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="Panithi Makthiengtrong (Thee)"
      href={new URL("feed.xml", Astro.site)}
    />
  </head>
  <body class={className}>
    <slot />
  </body>
</html>

<style is:global>
  .social-icon {
    @apply h-5 w-5 cursor-pointer text-gray-900 transition-colors duration-300 ease-in-out hover:text-betich-dark;
  }
</style>

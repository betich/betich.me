---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { FiExternalLink } from "react-icons/fi";

const { currentPath, prose: proseProp = false, frontmatter } = Astro.props;
const prose = proseProp || frontmatter?.prose || false;
const pathname = currentPath ?? Astro.url.pathname;

const nav = [
  { label: "about", href: "/about" },
  { label: "projects", href: "/projects" },
  { label: "notes", href: "/notes" },
];

function isActive(href: string) {
  if (href === "/about") return pathname === "/" || pathname === "/about" || pathname.startsWith("/about");
  return pathname === href || pathname.startsWith(href + "/");
}
---

<BaseLayout className="bg-white font-sans text-gray-900 antialiased">
  <div class="flex min-h-screen">
    <!-- Sidebar -->
    <nav
      class="flex w-[82px] shrink-0 flex-col items-end border-r border-betich-light px-1 pt-8 sm:w-[112] sm:px-2 sm:pt-12 md:w-[130px] md:px-3 md:pt-16"
    >
      {
        nav.map(({ label, href }) => (
          <a
            href={href}
            class:list={[
              "mb-1 block px-2 font-mono text-xs leading-relaxed transition-colors sm:mb-1.5 sm:text-sm",
              isActive(href) ? "italic text-betich-dark" : "text-gray-400 hover:text-gray-500",
            ]}
          >
            {label}
          </a>
        ))
      }

      <a
        href="https://resume.betich.me"
        target="_blank"
        rel="noopener noreferrer"
        class="mb-1 mt-6 flex items-center gap-1 px-2 font-mono text-xs leading-relaxed text-gray-400 transition-colors hover:text-gray-500 sm:mb-1.5 sm:text-sm"
      >
        Résumé
        <FiExternalLink client:load className="h-3 w-3 shrink-0" />
      </a>
    </nav>

    <!-- Content -->
    <main class="min-w-0 max-w-4xl flex-1 px-5 pb-16 pt-8 sm:px-8 sm:pt-12 md:px-12 md:pt-16">
      <div class:list={["content-fade", prose && "prose prose-sm prose-gray max-w-none"]}>
        <slot />
      </div>
    </main>
  </div>
</BaseLayout>

<style>
  .content-fade {
    animation: fadeIn 0.25s ease-out both;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(6px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>

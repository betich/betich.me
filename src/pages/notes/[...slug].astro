---
import SidebarLayout from "@/layouts/SidebarLayout.astro";
import { getCollection } from "astro:content";
import { FaRss } from "react-icons/fa";
import { FiTwitter, FiLink, FiChevronLeft, FiChevronRight } from "react-icons/fi";
import { mdxToText } from "@/utils/sanitize";

export async function getStaticPaths() {
  const notes = (await getCollection("notes", ({ data }) => !data.draft)).sort(
    (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
  );
  return notes.map((note, i) => ({
    params: { slug: note.slug },
    props: { note, prev: notes[i + 1] ?? null, next: notes[i - 1] ?? null },
  }));
}

const { note, prev, next } = Astro.props;
const { Content } = await note.render();
const description = mdxToText(note.body);

const pageUrl = new URL(`/notes/${note.slug}`, Astro.site).toString();
const tweetUrl = `https://x.com/intent/tweet?text=${encodeURIComponent(note.data.title)}&url=${encodeURIComponent(pageUrl)}`;

function formatDate(date: Date) {
  const y = date.getFullYear();
  const m = String(date.getMonth() + 1).padStart(2, "0");
  const d = String(date.getDate()).padStart(2, "0");
  const h = String(date.getHours()).padStart(2, "0");
  const min = String(date.getMinutes()).padStart(2, "0");
  return `${y}.${m}.${d} ${h}:${min}`;
}
---

<SidebarLayout currentPath="/notes" title={note.data.title} description={description} ogImage={`/og/${note.slug}.png`}>
  <article class="prose prose-sm prose-gray max-w-none">
    <p class="not-prose mb-4 font-mono text-xs tracking-tight text-betich-dark">{formatDate(note.data.date)}</p>
    <h1 class="not-prose mb-6 font-mono text-xl font-bold text-betich-dark">{note.data.title}</h1>
    <Content />
  </article>

  <!-- Share + RSS -->
  <div class="not-prose mt-10 flex items-center gap-4 border-t border-betich-light pt-6">
    <span class="font-mono text-xs text-gray-400">share</span>
    <a
      href={tweetUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="tooltip text-gray-400 transition-colors hover:text-betich-dark"
      data-tip="Share on X"
    >
      <FiTwitter client:load className="h-4 w-4" />
    </a>
    <button
      id="copy-link"
      class="tooltip text-gray-400 transition-colors hover:text-betich-dark"
      data-tip="Copy link"
      data-url={pageUrl}
    >
      <FiLink client:load className="h-4 w-4" />
    </button>
    <a
      href="/feed.xml"
      target="_blank"
      rel="noopener noreferrer"
      class="tooltip ml-auto text-gray-400 transition-colors hover:text-betich-dark"
      data-tip="RSS feed"
    >
      <FaRss client:load className="h-4 w-4" />
    </a>
  </div>

  <!-- Prev / Next -->
  <nav class="not-prose mt-6 grid grid-cols-2 gap-4">
    {prev ? (
      <a
        href={`/notes/${prev.slug}`}
        class="tooltip group flex flex-col gap-1 rounded-lg border border-betich-light px-4 py-3 transition-colors hover:border-betich-dark"
        data-tip={prev.data.title}
        data-tip-pos="top-left"
      >
        <span class="flex items-center gap-1 font-mono text-xs text-gray-400 transition-colors group-hover:text-betich-dark"><FiChevronLeft client:load className="h-3 w-3" /> previous</span>
        <span class="text-sm text-gray-700 transition-colors group-hover:text-betich-dark">{prev.data.title}</span>
      </a>
    ) : (
      <div class="flex flex-col gap-1 rounded-lg border border-gray-200 px-4 py-3 opacity-60 cursor-not-allowed">
        <span class="flex items-center gap-1 font-mono text-xs text-gray-400"><FiChevronLeft client:load className="h-3 w-3" /> previous</span>
        <span class="text-sm text-gray-500">nothing here</span>
      </div>
    )}

    {next ? (
      <a
        href={`/notes/${next.slug}`}
        class="tooltip group flex flex-col items-end gap-1 rounded-lg border border-betich-light px-4 py-3 transition-colors hover:border-betich-dark"
        data-tip={next.data.title}
        data-tip-pos="top-right"
      >
        <span class="flex items-center gap-1 font-mono text-xs text-gray-400 transition-colors group-hover:text-betich-dark">next <FiChevronRight client:load className="h-3 w-3" /></span>
        <span class="text-sm text-gray-700 text-right transition-colors group-hover:text-betich-dark">{next.data.title}</span>
      </a>
    ) : (
      <div class="flex flex-col items-end gap-1 rounded-lg border border-gray-200 px-4 py-3 opacity-60 cursor-not-allowed">
        <span class="flex items-center gap-1 font-mono text-xs text-gray-400">next <FiChevronRight client:load className="h-3 w-3" /></span>
        <span class="text-sm text-gray-500">nothing here</span>
      </div>
    )}
  </nav>
</SidebarLayout>

<!-- Toast -->
<div id="toast" aria-live="polite">Link copied!</div>

<style>
  /* Tooltip */
  .tooltip {
    position: relative;
  }
  .tooltip::after {
    content: attr(data-tip);
    position: absolute;
    bottom: calc(100% + 6px);
    left: 50%;
    transform: translateX(-50%);
    white-space: nowrap;
    background: #1f2937;
    color: #fff;
    font-size: 11px;
    font-family: "Roboto Mono", monospace;
    padding: 3px 8px;
    border-radius: 4px;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.15s ease;
  }
  .tooltip[data-tip-pos="top-left"]::after {
    left: 0;
    transform: none;
  }
  .tooltip[data-tip-pos="top-right"]::after {
    left: auto;
    right: 0;
    transform: none;
  }
  .tooltip:hover::after {
    opacity: 1;
  }

  /* Toast */
  #toast {
    position: fixed;
    bottom: 24px;
    right: 24px;
    background: #1f2937;
    color: #fff;
    font-size: 12px;
    font-family: "Roboto Mono", monospace;
    padding: 8px 16px;
    border-radius: 6px;
    pointer-events: none;
    opacity: 0;
    transform: translateY(6px);
    transition: opacity 0.2s ease, transform 0.2s ease;
    z-index: 50;
  }
  #toast.show {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  const btn = document.getElementById("copy-link");
  const toast = document.getElementById("toast");

  btn?.addEventListener("click", () => {
    const url = (btn as HTMLButtonElement).dataset.url ?? window.location.href;
    navigator.clipboard.writeText(url).then(() => {
      toast?.classList.add("show");
      setTimeout(() => toast?.classList.remove("show"), 2000);
    });
  });
</script>
